# Telegram bot used by the contact form (server-side only — never exposed to the client).
# Create a bot with @BotFather to get the token, and use @userinfobot to find your chat id.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Optional: Google Search Console verification (Search Console → HTML tag →
# the content="..." value). Leave unset to omit the verification meta tag.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
